{%- comment -%}
  ETHOSSENCE SEGMENT PRICING — PRODUCT CARD (COMPACT)
  DISPLAYS SEGMENT-BASED PRICING ON PRODUCT CARDS FOR ELIGIBLE LOGGED-IN CUSTOMERS.
  RENDERS BEFORE DAWN'S PRICE SNIPPET SO CSS ADJACENT SIBLING SELECTOR
  CAN HIDE THE DEFAULT PRICE WHEN SEGMENT PRICING IS ACTIVE.

  ACCEPTS:
  - card_product: {Object} PRODUCT LIQUID OBJECT
{%- endcomment -%}

{%- liquid
  comment
    GUARD: EXIT IF CUSTOMER IS NOT LOGGED IN
  endcomment
  unless customer
    break
  endunless

  comment
    GUARD: EXIT IF CUSTOMER HAS NO PRICING SEGMENT ASSIGNED
  endcomment
  assign s_esp_segment = customer.metafields.ethossence.pricing_segment.value
  if s_esp_segment == blank
    break
  endif

  comment
    GUARD: EXIT IF SEGMENT IS NOT ACTIVE
  endcomment
  assign s_esp_active_raw = s_esp_segment.active
  unless s_esp_active_raw == true or s_esp_active_raw == 'true'
    break
  endunless

  comment
    EXTRACT SEGMENT DATA
  endcomment
  assign s_esp_discount_pct = s_esp_segment.discount_percentage | plus: 0
  assign s_esp_eligible_collections = s_esp_segment.eligible_collections.value

  comment
    GUARD: EXIT IF DISCOUNT PERCENTAGE IS 0
  endcomment
  if s_esp_discount_pct == 0
    break
  endif

  comment
    CHECK COLLECTION ELIGIBILITY
  endcomment
  assign s_esp_product_eligible = false

  for s_esp_collection in s_esp_eligible_collections
    for s_esp_product_collection in card_product.collections
      if s_esp_product_collection.id == s_esp_collection.id
        assign s_esp_product_eligible = true
        break
      endif
    endfor
    if s_esp_product_eligible
      break
    endif
  endfor

  unless s_esp_product_eligible
    break
  endunless

  comment
    GUARD: EXIT IF PRODUCT HAS ACTIVE COMPARE-AT PRICE (SALE PRICING TAKES PRECEDENCE)
  endcomment
  if card_product.compare_at_price > card_product.price
    break
  endif

  comment
    CALCULATE SEGMENT PRICE USING INTEGER MATH (PRICES ARE IN CENTS)
  endcomment
  assign s_esp_factor = 100 | minus: s_esp_discount_pct
  assign s_esp_segment_price = card_product.price | times: s_esp_factor | divided_by: 100

  comment
    FORMAT PRICES RESPECTING STORE CURRENCY SETTINGS
  endcomment
  if settings.currency_code_enabled
    assign s_esp_regular_money = card_product.price | money_with_currency
    assign s_esp_segment_money = s_esp_segment_price | money_with_currency
  else
    assign s_esp_regular_money = card_product.price | money
    assign s_esp_segment_money = s_esp_segment_price | money
  endif

  comment
    HANDLE PRICE VARIES (FROM PRICING)
  endcomment
  if card_product.price_varies
    assign s_esp_segment_money = 'products.product.price.from_price_html' | t: price: s_esp_segment_money
  endif
-%}

{%- comment -%} CARD SEGMENT PRICING DISPLAY {%- endcomment -%}
{{ 'ethossence-segment-pricing.css' | asset_url | stylesheet_tag }}
<div class="ethossence-segment-pricing-card" data-active="true">
  <span class="ethossence-segment-pricing-card__discounted">
    Price {{ s_esp_segment_money }}
  </span>
  <span class="ethossence-segment-pricing-card__regular">
    <s>{{ s_esp_regular_money }}</s>
  </span>
</div>
