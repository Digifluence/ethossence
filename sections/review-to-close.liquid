{%- comment -%}
  Review-to-Close Section for the Ethossence Shopify Theme.
  Provides a modular B2B review request experience with configurable display modes
  (slide-down or drawer), content blocks (Heading, Caption, Text, Button), and a
  Form block that loads contact and project fields dynamically via Make.com webhooks.
  Supports Basic/Detailed form modes with auto-detection based on customer sign-in status.
{%- endcomment -%}

{{ 'review-to-close.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- comment -%} FIND FORM BLOCK FOR JS CONFIGURATION {%- endcomment -%}
{%- liquid
  assign form_block = nil
  for block in section.blocks
    if block.type == 'form'
      assign form_block = block
      break
    endif
  endfor
-%}

<div class="color-{{ section.settings.color_scheme }} gradient {% if section.settings.full_width %}page-width {% endif %}section-{{ section.id }}-padding">
  <div class="frame {% if section.settings.full_width == false %}width-90{% endif %}">
      {%- comment -%} PRE-EXPAND CONTENT (ON_BUTTON_CLICK MODE ONLY) {%- endcomment -%}
      {%- if section.settings.expand_status == 'on_button_click' -%}
        <div class="request-review__lead-in text-{{ section.settings.pre_expand_content_alignment }}">
          {%- if section.settings.pre_expand_heading != blank -%}
            <{{ section.settings.pre_expand_heading_size }} class="{{ section.settings.pre_expand_heading_size }}">
              {{ section.settings.pre_expand_heading }}
            </{{ section.settings.pre_expand_heading_size }}>
          {%- endif -%}
          {%- if section.settings.pre_expand_text != blank -%}
            <div class="request-review__lead-in-text rte">
              {{ section.settings.pre_expand_text }}
            </div>
          {%- endif -%}
          <button type="button" id="review-form-cta" class="button button--primary">
            {{ section.settings.expand_button_label | default: 'Get started >' }}
          </button>
        </div>
      {%- endif -%}

      {%- comment -%} DISPLAY WRAPPER OPEN {%- endcomment -%}
      {%- if section.settings.expand_status == 'on_button_click' and section.settings.display_type == 'slide_down' -%}
        <div id="review-form-dropdown" class="form-dropdown">
          <div class="form-dropdown__content">
      {%- elsif section.settings.expand_status == 'on_button_click' and section.settings.display_type == 'drawer' -%}
        <div id="review-form-drawer" class="drawer drawer--right">
          <div class="drawer__header">
            {%- if form_block -%}
              <{{ form_block.settings.heading_size }} class="form-title {{ form_block.settings.heading_size }}" id="form-heading-drawer">
                {{ form_block.settings.heading | default: 'About You' }}
              </{{ form_block.settings.heading_size }}>
            {%- endif -%}
            <button type="button" class="drawer__close" id="close-form-drawer" aria-label="Close form"><span class="text-xlarge">X</span></button>
          </div>
          <div class="drawer__inner">
      {%- endif -%}

      {%- comment -%} BLOCK RENDERING LOOP {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'heading' -%}
            {%- comment -%} HEADING BLOCK {%- endcomment -%}
            {%- liquid
              assign show_block = false
              if block.settings.viewable == 'both'
                assign show_block = true
              elsif block.settings.viewable == 'guests' and customer == null
                assign show_block = true
              elsif block.settings.viewable == 'customers' and customer != null
                assign show_block = true
              endif
            -%}
            {%- if show_block -%}
              <{{ block.settings.heading_size }} class="rich-text__heading rte inline-richtext {{ block.settings.heading_size }} text-{{ block.settings.content_alignment }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {{ block.settings.heading }}
              </{{ block.settings.heading_size }}>
            {%- endif -%}

          {%- when 'caption' -%}
            {%- comment -%} CAPTION BLOCK {%- endcomment -%}
            {%- liquid
              assign show_block = false
              if block.settings.viewable == 'both'
                assign show_block = true
              elsif block.settings.viewable == 'guests' and customer == null
                assign show_block = true
              elsif block.settings.viewable == 'customers' and customer != null
                assign show_block = true
              endif
            -%}
            {%- if show_block -%}
              <p class="rich-text__caption {{ block.settings.text_style }} {{ block.settings.text_style }}--{{ block.settings.text_size }} text-{{ block.settings.content_alignment }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {{ block.settings.caption | escape }}
              </p>
            {%- endif -%}

          {%- when 'text' -%}
            {%- comment -%} TEXT BLOCK {%- endcomment -%}
            {%- liquid
              assign show_block = false
              if block.settings.viewable == 'both'
                assign show_block = true
              elsif block.settings.viewable == 'guests' and customer == null
                assign show_block = true
              elsif block.settings.viewable == 'customers' and customer != null
                assign show_block = true
              endif
            -%}
            {%- if show_block -%}
              <div class="rich-text__text rte text-{{ block.settings.content_alignment }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {{ block.settings.text }}
              </div>
            {%- endif -%}

          {%- when 'button' -%}
            {%- comment -%} BUTTON BLOCK {%- endcomment -%}
            {%- liquid
              assign show_block = false
              if block.settings.viewable == 'both'
                assign show_block = true
              elsif block.settings.viewable == 'guests' and customer == null
                assign show_block = true
              elsif block.settings.viewable == 'customers' and customer != null
                assign show_block = true
              endif
            -%}
            {%- if show_block -%}
              <div class="rich-text__buttons{% if block.settings.button_label != blank and block.settings.button_label_2 != blank %} rich-text__buttons--multiple{% endif %} text-{{ block.settings.content_alignment }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {%- if block.settings.button_label != blank -%}
                  <a
                    {% if block.settings.button_link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.button_link }}"
                    {% endif %}
                    class="button{% if block.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}"
                  >
                    {{- block.settings.button_label | escape -}}
                  </a>
                {%- endif -%}
                {%- if block.settings.button_label_2 != blank -%}
                  <a
                    {% if block.settings.button_link_2 == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.button_link_2 }}"
                    {% endif %}
                    class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %}"
                  >
                    {{- block.settings.button_label_2 | escape -}}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}

          {%- when 'form' -%}
            {%- comment -%} FORM BLOCK {%- endcomment -%}

            {%- style -%}
              .block-{{ block.id }}-padding {
                  padding-top: {{ block.settings.padding_top | times: 0.75 | round: 0 }}px;
                  padding-bottom: {{ block.settings.padding_bottom | times: 0.75 | round: 0 }}px;
              }

              @media screen and (min-width: 750px) {
                  .block-{{ block.id }}-padding {
                    padding-top: {{ block.settings.padding_top }}px;
                    padding-bottom: {{ block.settings.padding_bottom }}px;
                  }
              }
            {%- endstyle -%}

            <div class="color-{{ block.settings.color_scheme }} gradient">
              <div class="block-{{ block.id }}-padding text-{{ block.settings.content_alignment }}">

                {%- comment -%} FORM CONTENT {%- endcomment -%}
                <div class="request-review__form-wrapper" id="review-form-content"
                     data-is-customer="{% if customer %}true{% else %}false{% endif %}"
                     data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
                     data-customer-email="{% if customer %}{{ customer.email }}{% endif %}"
                     {% if section.settings.expand_status == 'on_button_click' %}style="display: none;"{% endif %}>

                  {%- comment -%} FORM HEADER: HEADING + TOGGLE (LEFT) | SIGN-IN/STATUS (RIGHT) {%- endcomment -%}
                  <div class="request-review__form-header">
                    <div class="request-review__form-header-left">
                      {%- if section.settings.expand_status != 'on_button_click' or section.settings.display_type != 'drawer' -%}
                        <{{ block.settings.heading_size }} class="form-title {{ block.settings.heading_size }}" id="form-heading">
                          {{ block.settings.heading | default: 'About You' }}
                        </{{ block.settings.heading_size }}>
                      {%- endif -%}

                      {%- if block.settings.contact_default_mode == 'basic' -%}
                        <fieldset class="request-review__mode-toggle" role="radiogroup">
                          <legend class="visually-hidden">Choose form detail level</legend>
                          <label class="request-review__mode-option">
                            <input type="radio" name="form_detail_level" value="basic"
                                   {% unless customer %}checked{% endunless %}>
                            <span>Basic</span>
                          </label>
                          <label class="request-review__mode-option">
                            <input type="radio" name="form_detail_level" value="detailed"
                                   {% if customer %}checked{% endif %}
                                   aria-describedby="mode-detailed-desc">
                            <span>Detailed</span>
                            <button type="button" class="request-review__tooltip-trigger" aria-label="What is detailed mode?">
                              <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16">
                                <circle cx="8" cy="8" r="7.5" fill="currentColor"/>
                                <text x="8" y="11.5" text-anchor="middle" font-size="10" fill="rgb(var(--color-background))" font-weight="700">?</text>
                              </svg>
                            </button>
                            <div class="request-review__tooltip" id="mode-detailed-desc" role="tooltip" aria-hidden="true">
                              Completing a detailed profile allows us to provide better initial responses, saving you time.
                            </div>
                          </label>
                        </fieldset>
                      {%- endif -%}
                    </div>

                    <div class="request-review__form-header-right">
                      {%- if customer -%}
                        <div class="request-review__account-status">
                          <span class="request-review__signed-in-status">Signed in as {{ customer.email }}</span>
                          <a class="request-review__switch-account-link" href="{{ routes.storefront_logout_url }}">Switch account</a>
                        </div>
                      {%- else -%}
                        <a class="request-review__sign-in-link" href="{{ routes.storefront_login_url }}"><strong>Sign In &raquo;</strong></a>
                      {%- endif -%}
                    </div>
                  </div>

                  {%- comment -%} STEP INDICATOR {%- endcomment -%}
                  <div class="request-review__step-indicator" id="step-indicator" aria-live="polite">
                    <span id="step-indicator-text">Step 1 of 2</span>
                  </div>

                  {%- comment -%} STEP 1: ABOUT YOU (EDITABLE FORM) {%- endcomment -%}
                  <div id="step-1-form" class="request-review__step request-review__step--active">

                    {%- comment -%} BASIC CONTACT FIELDS (ALWAYS RENDERED IN LIQUID) {%- endcomment -%}
                    <div id="basic-fields-container" class="request-review__basic-fields">
                      <div class="request-review__fields-grid">
                        <div class="field">
                          <input class="field__input" type="text" id="firstName" name="firstName"
                                 placeholder="First name" required autocomplete="given-name"
                                 aria-label="First name" aria-required="true"
                                 {% if customer %}value="{{ customer.first_name | escape }}"{% endif %}>
                          <label class="field__label" for="firstName">First name <span class="required-marker">*</span></label>
                        </div>
                        <div class="field">
                          <input class="field__input" type="text" id="lastName" name="lastName"
                                 placeholder="Last name" required autocomplete="family-name"
                                 aria-label="Last name" aria-required="true"
                                 {% if customer %}value="{{ customer.last_name | escape }}"{% endif %}>
                          <label class="field__label" for="lastName">Last name <span class="required-marker">*</span></label>
                        </div>
                        <div class="field request-review__field--full">
                          <input class="field__input" type="text" id="company" name="company"
                                 placeholder="Company" required autocomplete="organization"
                                 aria-label="Company" aria-required="true"
                                 {% if customer and customer.default_address %}value="{{ customer.default_address.company | escape }}"{% endif %}>
                          <label class="field__label" for="company">Company <span class="required-marker">*</span></label>
                        </div>
                        <div class="field">
                          <input class="field__input" type="email" id="email" name="email"
                                 placeholder="Email" required autocomplete="email"
                                 aria-label="Email" aria-required="true"
                                 {% if customer %}value="{{ customer.email | escape }}"{% endif %}>
                          <label class="field__label" for="email">Email <span class="required-marker">*</span></label>
                        </div>
                        <div class="field">
                          <input class="field__input" type="tel" id="phone" name="phone"
                                 placeholder="+1 (555) 123-4567" autocomplete="tel"
                                 aria-label="Phone"
                                 {% if customer and customer.default_address %}value="{{ customer.phone | default: customer.default_address.phone | escape }}"{% endif %}>
                          <label class="field__label" for="phone">Phone</label>
                          <small class="field-help">Include country code, e.g. +1 for US</small>
                        </div>
                        <div class="field request-review__field--full">
                          <select class="field__input ethossence-select" id="country" name="country" aria-label="Country">
                            <option value="" selected>Select country</option>
                            <option value="US"{% if customer and customer.default_address.country_code == 'US' %} selected{% endif %}>United States</option>
                            <option value="AR"{% if customer and customer.default_address.country_code == 'AR' %} selected{% endif %}>Argentina</option>
                            <option value="AT"{% if customer and customer.default_address.country_code == 'AT' %} selected{% endif %}>Austria</option>
                            <option value="AU"{% if customer and customer.default_address.country_code == 'AU' %} selected{% endif %}>Australia</option>
                            <option value="BE"{% if customer and customer.default_address.country_code == 'BE' %} selected{% endif %}>Belgium</option>
                            <option value="BR"{% if customer and customer.default_address.country_code == 'BR' %} selected{% endif %}>Brazil</option>
                            <option value="CA"{% if customer and customer.default_address.country_code == 'CA' %} selected{% endif %}>Canada</option>
                            <option value="CL"{% if customer and customer.default_address.country_code == 'CL' %} selected{% endif %}>Chile</option>
                            <option value="CN"{% if customer and customer.default_address.country_code == 'CN' %} selected{% endif %}>China</option>
                            <option value="CO"{% if customer and customer.default_address.country_code == 'CO' %} selected{% endif %}>Colombia</option>
                            <option value="CZ"{% if customer and customer.default_address.country_code == 'CZ' %} selected{% endif %}>Czech Republic</option>
                            <option value="DE"{% if customer and customer.default_address.country_code == 'DE' %} selected{% endif %}>Germany</option>
                            <option value="DK"{% if customer and customer.default_address.country_code == 'DK' %} selected{% endif %}>Denmark</option>
                            <option value="EG"{% if customer and customer.default_address.country_code == 'EG' %} selected{% endif %}>Egypt</option>
                            <option value="ES"{% if customer and customer.default_address.country_code == 'ES' %} selected{% endif %}>Spain</option>
                            <option value="FI"{% if customer and customer.default_address.country_code == 'FI' %} selected{% endif %}>Finland</option>
                            <option value="FR"{% if customer and customer.default_address.country_code == 'FR' %} selected{% endif %}>France</option>
                            <option value="GR"{% if customer and customer.default_address.country_code == 'GR' %} selected{% endif %}>Greece</option>
                            <option value="HU"{% if customer and customer.default_address.country_code == 'HU' %} selected{% endif %}>Hungary</option>
                            <option value="ID"{% if customer and customer.default_address.country_code == 'ID' %} selected{% endif %}>Indonesia</option>
                            <option value="IE"{% if customer and customer.default_address.country_code == 'IE' %} selected{% endif %}>Ireland</option>
                            <option value="IL"{% if customer and customer.default_address.country_code == 'IL' %} selected{% endif %}>Israel</option>
                            <option value="IN"{% if customer and customer.default_address.country_code == 'IN' %} selected{% endif %}>India</option>
                            <option value="IT"{% if customer and customer.default_address.country_code == 'IT' %} selected{% endif %}>Italy</option>
                            <option value="JP"{% if customer and customer.default_address.country_code == 'JP' %} selected{% endif %}>Japan</option>
                            <option value="KE"{% if customer and customer.default_address.country_code == 'KE' %} selected{% endif %}>Kenya</option>
                            <option value="KR"{% if customer and customer.default_address.country_code == 'KR' %} selected{% endif %}>South Korea</option>
                            <option value="MX"{% if customer and customer.default_address.country_code == 'MX' %} selected{% endif %}>Mexico</option>
                            <option value="MY"{% if customer and customer.default_address.country_code == 'MY' %} selected{% endif %}>Malaysia</option>
                            <option value="NG"{% if customer and customer.default_address.country_code == 'NG' %} selected{% endif %}>Nigeria</option>
                            <option value="NL"{% if customer and customer.default_address.country_code == 'NL' %} selected{% endif %}>Netherlands</option>
                            <option value="NO"{% if customer and customer.default_address.country_code == 'NO' %} selected{% endif %}>Norway</option>
                            <option value="NZ"{% if customer and customer.default_address.country_code == 'NZ' %} selected{% endif %}>New Zealand</option>
                            <option value="PA"{% if customer and customer.default_address.country_code == 'PA' %} selected{% endif %}>Panama</option>
                            <option value="PH"{% if customer and customer.default_address.country_code == 'PH' %} selected{% endif %}>Philippines</option>
                            <option value="PL"{% if customer and customer.default_address.country_code == 'PL' %} selected{% endif %}>Poland</option>
                            <option value="PT"{% if customer and customer.default_address.country_code == 'PT' %} selected{% endif %}>Portugal</option>
                            <option value="SA"{% if customer and customer.default_address.country_code == 'SA' %} selected{% endif %}>Saudi Arabia</option>
                            <option value="SE"{% if customer and customer.default_address.country_code == 'SE' %} selected{% endif %}>Sweden</option>
                            <option value="SG"{% if customer and customer.default_address.country_code == 'SG' %} selected{% endif %}>Singapore</option>
                            <option value="CH"{% if customer and customer.default_address.country_code == 'CH' %} selected{% endif %}>Switzerland</option>
                            <option value="TH"{% if customer and customer.default_address.country_code == 'TH' %} selected{% endif %}>Thailand</option>
                            <option value="TR"{% if customer and customer.default_address.country_code == 'TR' %} selected{% endif %}>Turkey</option>
                            <option value="UA"{% if customer and customer.default_address.country_code == 'UA' %} selected{% endif %}>Ukraine</option>
                            <option value="GB"{% if customer and customer.default_address.country_code == 'GB' %} selected{% endif %}>United Kingdom</option>
                            <option value="VN"{% if customer and customer.default_address.country_code == 'VN' %} selected{% endif %}>Vietnam</option>
                            <option value="ZA"{% if customer and customer.default_address.country_code == 'ZA' %} selected{% endif %}>South Africa</option>
                            <option value="Other">Other</option>
                          </select>
                        </div>
                        <div class="field request-review__field--full" id="country-other-field" style="display: none;">
                          <input class="field__input" type="text" id="countryOther" name="countryOther"
                                 placeholder="Enter your country" aria-label="Other country">
                          <label class="field__label" for="countryOther">Other country</label>
                        </div>
                      </div>
                    </div>

                    {%- comment -%} DETAILED CONTACT FIELDS (LOADED FROM WEBHOOK) {%- endcomment -%}
                    <div id="detailed-contact-container" class="request-review__detailed-fields">
                      <div class="loading-spinner" style="display: none;">Loading detailed fields...</div>
                    </div>

                    {%- comment -%} STEP 1 ACTION BUTTONS {%- endcomment -%}
                    <div class="request-review__step-actions" id="step-1-actions">
                      <button type="button" id="btn-next-step" class="button button--primary">Next</button>
                      <div id="step-1-message" style="display: none;"></div>
                    </div>

                  </div>

                  {%- comment -%} STEP 1: SUMMARY CARD (COLLAPSED VIEW WHEN ON STEP 2) {%- endcomment -%}
                  <div id="step-1-summary" class="request-review__summary-card" role="region" aria-label="Contact information summary" style="display: none;">
                    <div class="request-review__summary-header">
                      <span class="request-review__summary-label">Step 1 of 2</span>
                      <a href="#" id="btn-edit-step1" class="request-review__summary-edit" role="button">Edit</a>
                    </div>
                    <div class="request-review__summary-details" id="summary-details">
                    </div>
                  </div>

                  {%- comment -%} STEP 2: PROJECT DETAILS {%- endcomment -%}
                  <div id="step-2-form" class="request-review__step" style="display: none;">

                    {%- comment -%} SUCCESS / ERROR MESSAGE {%- endcomment -%}
                    <div id="save-cart-message" style="display: none;"></div>

                    {%- comment -%} PROJECT FIELDS (LOADED FROM WEBHOOK) {%- endcomment -%}
                    <div id="project-fields-container" class="request-review__project-fields">
                      <div class="loading-spinner" style="display: none;">Loading project fields...</div>
                    </div>

                    {%- comment -%} STEP 2 ACTION BUTTONS {%- endcomment -%}
                    <div class="request-review__step-actions" id="step-2-actions">
                      <button type="button" id="save-cart-draft" class="button button--primary">Submit for Review</button>
                      <div class="request-review__skip-link">
                        <a href="#" id="btn-skip-submit" role="button">Skip project details and submit with request to contact</a>
                      </div>
                    </div>

                  </div>

                </div>
                {%- comment -%} END FORM CONTENT {%- endcomment -%}

              </div>
            </div>

        {%- endcase -%}
      {%- endfor -%}

      {%- comment -%} DISPLAY WRAPPER CLOSE {%- endcomment -%}
      {%- if section.settings.expand_status == 'on_button_click' and section.settings.display_type == 'slide_down' -%}
            <div>
              <button type="button" class="button button--small button--secondary dropdown__close float-right" id="close-form-dropdown" aria-label="Close form">Cancel</button>
            </div>
          </div>
        </div>
      {%- elsif section.settings.expand_status == 'on_button_click' and section.settings.display_type == 'drawer' -%}
          </div>
        </div>
        <div class="drawer__overlay" id="review-form-overlay"></div>
      {%- endif -%}

  </div>
</div>

{%- comment -%} JAVASCRIPT {%- endcomment -%}
<script src="{{ 'review-to-close.js' | asset_url }}" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof initReviewToClose === 'function') {
      initReviewToClose({
        displayType: '{{ section.settings.display_type }}',
        expandStatus: '{{ section.settings.expand_status }}',
        contactDefaultMode: '{{ form_block.settings.contact_default_mode }}',
        isCustomer: {% if customer %}true{% else %}false{% endif %}
      });
    }
  });
</script>

{% schema %}
{
  "name": "Review-to-Close",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": true,
      "label": "t:sections.rich-text.settings.full_width.label"
    },
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "select",
      "id": "display_type",
      "label": "Type",
      "options": [
